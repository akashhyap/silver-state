---
import { Image } from 'astro:assets';
import imgFilter   from '../../assets/images/service-hvac-filter.jpg';
import imgHeating  from '../../assets/images/service-heating.jpg';
import imgPlumbing from '../../assets/images/service-plumbing.jpg';
import imgCommercial from '../../assets/images/service-commercial.jpg';

const services = [
  {
    title: 'Air Conditioning & Cooling',
    desc:  'Beat the heat with efficient, reliable AC repair, installation, and maintenance services that ensure your indoor comfort even during the hottest days.',
    href:  '/residential/hvac/',
    img:   imgFilter,
    alt:   'HVAC air filter and furnace unit',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>`,
  },
  {
    title: 'Heating Solutions',
    desc:  'From furnace tune-ups to full system installations, our licensed experts deliver warm, safe, and energy-efficient heating for your home or commercial space.',
    href:  '/residential/hvac/furnace-repair/',
    img:   imgHeating,
    alt:   'HVAC technician installing a heating system',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"/><path stroke-linecap="round" stroke-linejoin="round" d="M9.879 16.121A3 3 0 1012.015 11L11 14H9c0 .768.293 1.536.879 2.121z"/></svg>`,
  },
  {
    title: 'Plumbing Expertise',
    desc:  'Fast, friendly, and fully licensed plumbing services — from routine inspections and drain cleaning to complex water heater and pipe repairs.',
    href:  '/residential/plumbing/',
    img:   imgPlumbing,
    alt:   'Licensed plumber repairing a pipe under sink',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>`,
  },
  {
    title: 'Commercial Services',
    desc:  'Keep your business running smoothly with our specialized commercial services. We design, repair, and maintain systems that protect your products and ensure comfort for your team.',
    href:  '/commercial/',
    img:   imgCommercial,
    alt:   'Commercial HVAC refrigerant pressure gauges',
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>`,
  },
];
---

<section class="section-pad bg-white">
  <div class="container-site">
    <div class="text-center mb-14 aos-init">
      <p class="eyebrow mb-3">Our Services</p>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 lg:gap-6 text-left mt-6 mb-8 lg:mb-10">
        <h2 class="section-title-lg">Expert HVAC &<br/>Plumbing Solutions</h2>
        <p class="font-body text-gray-500 text-base leading-relaxed self-end">
          Our customers trust us because we put their needs first. From fast response times to transparent pricing, we make home repairs stress-free. Whether it's fixing a broken AC in the summer, installing a new water heater, or keeping your business's refrigeration running smoothly, we get the job done right. Serving Nevada, California, Arizona, Utah & Texas.
        </p>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 stagger">
      {services.map(service => (
        <div class="aos-init group flex flex-col">
          <div class="rounded-2xl overflow-hidden aspect-[4/3] mb-4">
            <Image
              src={service.img}
              alt={service.alt}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            />
          </div>
          <div class="flex-1 flex flex-col border-b border-gray-200 pb-4">
            <div class="flex items-center justify-between mb-2">
              <h3 class="font-display font-bold text-base text-dark-900 group-hover:text-brand-blue transition-colors">
                {service.title}
              </h3>
              <a href={service.href} class="flex-shrink-0 w-7 h-7 rounded-full bg-brand-blue/10 flex items-center justify-center group-hover:bg-brand-blue transition-colors">
                <svg class="w-3.5 h-3.5 text-brand-blue group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
                </svg>
              </a>
            </div>
            <p class="font-body text-sm text-gray-500 leading-relaxed">{service.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
