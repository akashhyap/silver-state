---
// BlogPreviewSection.astro
import { Image } from 'astro:assets';
import blogSpring   from '../../assets/images/blog-spring-hvac.jpg';
import blogChecklist from '../../assets/images/blog-hvac-checklist.jpg';
import blogToilet   from '../../assets/images/blog-running-toilet.webp';

const posts = [
  {
    title:    'Spring HVAC Maintenance Checklist for Homeowners',
    excerpt:  'Get your system ready before the heat hits. Everything you need to check before summer.',
    category: 'HVAC',
    date:     'March 6, 2026',
    href:     '/blog/hvac/spring-hvac-maintenance-checklist/',
    img: blogSpring,
  },
  {
    title:    'The Ultimate HVAC Maintenance Checklist for Las Vegas Homeowners',
    excerpt:  'Living in Las Vegas means your HVAC is a lifeline. Here\'s how to protect it.',
    category: 'HVAC',
    date:     'February 18, 2026',
    href:     '/blog/hvac/hvac-maintenance-las-vegas/',
    img: blogChecklist,
  },
  {
    title:    'How to Troubleshoot a Running Toilet: DIY Tips & When to Call a Plumber',
    excerpt:  'A running toilet wastes hundreds of gallons a month. Here\'s how to fix it — or know when to call.',
    category: 'Plumbing',
    date:     'February 10, 2026',
    href:     '/blog/plumbing/running-toilet-troubleshoot/',
    img: blogToilet,
  },
];

const categoryColors: Record<string, string> = {
  'HVAC':      'bg-blue-100 text-brand-blue',
  'Plumbing':  'bg-cyan-100 text-cyan-700',
  'Commercial':'bg-slate-100 text-slate-700',
};
---

<section class="section-pad bg-brand-cream/40">
  <div class="container-site">

    <!-- Header -->
    <div class="flex items-end justify-between mb-12 aos-init">
      <div>
        <p class="eyebrow mb-3">Blog Posts & Articles</p>
        <h2 class="section-title max-w-sm">Read Our<br/>Latest Articles</h2>
      </div>
      <a href="/blog/" class="hidden md:inline-flex items-center gap-2 font-body font-semibold text-sm text-brand-blue hover:gap-3 transition-all">
        View all articles
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
      </a>
    </div>

    <!-- Blog grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 sm:gap-6 stagger">
      {posts.map(post => (
        <a href={post.href} class="aos-init card group flex flex-col overflow-hidden">
          <!-- Thumbnail -->
          <div class="aspect-[16/9] overflow-hidden">
            <Image src={post.img} alt={post.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
          </div>

          <!-- Body -->
          <div class="flex flex-col flex-1 p-6">
            <div class="flex items-center gap-3 mb-3">
              <span class={`font-body font-semibold text-xs px-2.5 py-1 rounded-full ${categoryColors[post.category] ?? 'bg-gray-100 text-gray-600'}`}>
                {post.category}
              </span>
              <span class="font-body text-xs text-gray-400">{post.date}</span>
            </div>

            <h3 class="font-display font-semibold text-base text-dark-900 leading-snug mb-2 group-hover:text-brand-blue transition-colors flex-1">
              {post.title}
            </h3>
            <p class="font-body text-sm text-gray-500 leading-relaxed mb-4 line-clamp-2">
              {post.excerpt}
            </p>

            <span class="inline-flex items-center gap-1.5 font-body font-semibold text-sm text-brand-blue group-hover:gap-2.5 transition-all mt-auto">
              Read More
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            </span>
          </div>
        </a>
      ))}
    </div>

    <!-- Mobile view-all -->
    <div class="text-center mt-10 md:hidden aos-init">
      <a href="/blog/" class="btn-primary">
        View All Articles
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
      </a>
    </div>

  </div>
</section>
