            (725) 213-7309
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Commercial panel -->
  <div class="desk-panel" id="desk-panel-commercial">
    <div class="desk-panel-head">
      <div class="desk-panel-title-row">
        <span class="desk-panel-title">Commercial</span>
        <a href="/commercial/" class="desk-panel-all">View All Services →</a>
      </div>
      <button class="desk-close" aria-label="Close menu">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
