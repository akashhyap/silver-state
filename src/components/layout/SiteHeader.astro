        <a href="/residential/plumbing/bathroom-plumbing/" class="desk-link">Bathroom Plumbing</a>
        <a href="/residential/plumbing/kitchen-plumbing/" class="desk-link">Kitchen Plumbing</a>
        <a href="/residential/plumbing/sewer-line-services/" class="desk-link">Sewer Line Services</a>
      </div>
      <div class="desk-promo">
        <div class="desk-promo-card">
          <span class="desk-promo-badge">24/7</span>
