---
// InPageCTA.astro
import { siteConfig } from '../../data/siteData';
interface Props {
  headline?: string;
  subline?: string;
}
const {
  headline = 'Ready to Schedule Service?',
  subline = 'Contact us online or call us today. Same-day appointments available.',
} = Astro.props;
---

<section class="bg-brand-blue py-14">
  <div class="container-site flex flex-col md:flex-row items-center justify-between gap-6">
    <div>
      <h2 class="font-display font-bold text-2xl md:text-3xl text-white">{headline}</h2>
      <p class="font-body text-white/80 mt-1">{subline}</p>
    </div>
    <div class="flex flex-wrap gap-3 flex-shrink-0">
      <a href="/contact-us/" class="btn-dark">
        Book Online
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </a>
      <a href={`tel:${siteConfig.phoneRaw}`} class="inline-flex items-center gap-2 bg-white/15 border border-white/30 text-white font-body font-semibold text-base px-6 py-3.5 rounded-full hover:bg-white/25 transition-all">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
          <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
        </svg>
        {siteConfig.phone}
      </a>
    </div>
  </div>
</section>
