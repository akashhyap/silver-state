---
// ServiceSidebar.astro
import { siteConfig } from '../../data/siteData';
interface Props {
  siblingLinks?: { label: string; href: string }[];
  currentHref?: string;
}
const { siblingLinks = [], currentHref = '' } = Astro.props;
---

<aside class="space-y-6">

  <!-- Quick Contact -->
  <div class="bg-brand-navy rounded-2xl p-6 text-white">
    <p class="font-body text-xs text-brand-sky uppercase tracking-widest font-semibold mb-3">Contact Us</p>
    <h3 class="font-display font-bold text-lg mb-4">Get a Free Estimate</h3>
    <form class="space-y-3" onsubmit="return false;">
      <input type="text" placeholder="Full Name" class="w-full bg-white/10 border border-white/20 rounded-xl px-4 py-2.5 text-sm font-body text-white placeholder-white/40 focus:outline-none focus:border-brand-sky transition-colors" />
      <input type="tel" placeholder="Phone Number" class="w-full bg-white/10 border border-white/20 rounded-xl px-4 py-2.5 text-sm font-body text-white placeholder-white/40 focus:outline-none focus:border-brand-sky transition-colors" />
      <input type="email" placeholder="Email Address" class="w-full bg-white/10 border border-white/20 rounded-xl px-4 py-2.5 text-sm font-body text-white placeholder-white/40 focus:outline-none focus:border-brand-sky transition-colors" />
      <textarea placeholder="Describe your issue..." rows="3" class="w-full bg-white/10 border border-white/20 rounded-xl px-4 py-2.5 text-sm font-body text-white placeholder-white/40 focus:outline-none focus:border-brand-sky transition-colors resize-none"></textarea>
      <button type="submit" class="w-full btn-primary justify-center">
        Request Service
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
      </button>
    </form>
    <div class="mt-4 pt-4 border-t border-white/10 text-center">
      <p class="font-body text-xs text-white/50 mb-1">Or call us directly</p>
      <a href={`tel:${siteConfig.phoneRaw}`} class="font-display font-bold text-brand-sky text-lg hover:text-white transition-colors">{siteConfig.phone}</a>
    </div>
  </div>

  <!-- Hours -->
  <div class="bg-gray-50 rounded-2xl p-5 border border-gray-100">
    <p class="font-body text-xs text-brand-blue uppercase tracking-widest font-semibold mb-3">Hours of Operation</p>
    <p class="font-body text-sm text-gray-600 leading-relaxed">
      We are open every day, Monday – Sunday, 24/7 to ensure you never wait for emergency service.
    </p>
    <div class="mt-3 flex items-center gap-2">
      <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse flex-shrink-0"></span>
      <span class="font-body text-sm font-semibold text-green-600">Available Now</span>
    </div>
  </div>

  <!-- Related services -->
  {siblingLinks.length > 0 && (
    <div class="bg-white rounded-2xl p-5 border border-gray-100 shadow-card">
      <p class="font-body text-xs text-brand-blue uppercase tracking-widest font-semibold mb-4">Related Services</p>
      <ul class="space-y-1">
        {siblingLinks.map(link => (
          <li>
            <a
              href={link.href}
              class={`flex items-center justify-between py-2 px-3 rounded-lg text-sm font-body transition-all ${
                link.href === currentHref
                  ? 'bg-brand-blue text-white font-semibold'
                  : 'text-gray-600 hover:bg-gray-50 hover:text-brand-blue'
              }`}
            >
              {link.label}
              <svg class="w-3.5 h-3.5 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            </a>
          </li>
        ))}
      </ul>
    </div>
  )}

</aside>
