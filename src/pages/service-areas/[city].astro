---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/ui/PageHero.astro';
import InPageCTA from '../../components/ui/InPageCTA.astro';
import ServiceSidebar from '../../components/ui/ServiceSidebar.astro';
import TrustStripSection from '../../components/sections/TrustStripSection.astro';
import { locations } from '../../data/siteData';

export async function getStaticPaths() {
  return locations.map(loc => ({
    params: { city: loc.slug },
    props: { loc },
  }));
}

const { loc } = Astro.props;

const allLocLinks = locations.map(l => ({
  label: `${l.city}, ${l.stateAbbr}`,
  href: `/service-areas/${l.slug}/`,
}));

const services = [
  { label: 'AC Repair & HVAC', href: '/residential/hvac/ac-repair/' },
  { label: 'Furnace Repair & Installation', href: '/residential/hvac/furnace-repair/' },
  { label: 'HVAC Maintenance', href: '/residential/hvac/hvac-maintenance/' },
  { label: 'Drain Cleaning', href: '/residential/plumbing/drain-cleaning/' },
  { label: 'Water Heater Services', href: '/residential/plumbing/water-heater-repair/' },
  { label: 'Leak Detection & Repair', href: '/residential/plumbing/leak-detection-repair/' },
  { label: 'Commercial HVAC', href: '/commercial/hvac/' },
  { label: 'Commercial Refrigeration', href: '/commercial/refrigeration/' },
  { label: 'Government Contracts', href: '/commercial/government-contracts/' },
];
---

<BaseLayout
  title={`HVAC & Plumbing Services in ${loc.city}, ${loc.stateAbbr}`}
  description={`Expert HVAC, plumbing & refrigeration services in ${loc.city}, ${loc.state}. Licensed technicians, same-day appointments, 24/7 emergency service. Call ${loc.phone}.`}
>
  <PageHero
    eyebrow={`${loc.city}, ${loc.stateAbbr}`}
    title={`Plumbing, Heating & Cooling Services in ${loc.city}, ${loc.stateAbbr}`}
    subtitle={loc.intro}
    breadcrumbs={[
      { label: 'Service Areas', href: '/service-areas/' },
      { label: `${loc.city}, ${loc.stateAbbr}`, href: '' },
    ]}
  />

  <section class="section-pad bg-white">
    <div class="container-site">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">

        <div class="lg:col-span-2 space-y-10">

          <!-- Local phone + address -->
          <div class="flex flex-col sm:flex-row gap-4">
            <a href={`tel:${loc.phoneRaw}`} class="flex items-center gap-3 bg-brand-blue/5 border border-brand-blue/20 rounded-2xl px-5 py-4 hover:bg-brand-blue/10 transition-colors">
              <svg class="w-5 h-5 text-brand-blue flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/></svg>
              <div>
                <p class="font-body text-xs text-gray-500">{loc.city} Direct Line</p>
                <p class="font-display font-bold text-brand-blue">{loc.phone}</p>
              </div>
            </a>
            <div class="flex items-center gap-3 bg-gray-50 border border-gray-200 rounded-2xl px-5 py-4">
              <svg class="w-5 h-5 text-gray-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              <div>
                <p class="font-body text-xs text-gray-500">Service Location</p>
                <p class="font-body text-sm font-medium text-gray-700">{loc.address}</p>
              </div>
            </div>
          </div>

          <!-- Services offered -->
          <div>
            <h2 class="font-display font-bold text-display-sm text-dark-900 mb-5">Services Available in {loc.city}</h2>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
              {services.map(s => (
                <a href={s.href} class="flex items-center gap-2 p-3 rounded-xl border border-gray-100 hover:border-brand-blue/30 hover:bg-blue-50/50 transition-all group">
                  <svg class="w-3.5 h-3.5 text-brand-blue flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
                  <span class="font-body text-sm text-gray-700 group-hover:text-brand-blue transition-colors">{s.label}</span>
                </a>
              ))}
            </div>
          </div>

          <!-- Climate + local context -->
          <div class="bg-brand-navy rounded-3xl p-8 text-white">
            <h2 class="font-display font-bold text-xl mb-3">Why {loc.city} Trusts Silver State</h2>
            <p class="font-body text-white/70 text-sm leading-relaxed mb-4">
              {loc.city} has unique demands shaped by {loc.climateAngle}. Our technicians know the local climate, building stock, and utility requirements — delivering service that's genuinely tailored to {loc.city} homeowners and businesses.
            </p>
            <div class="grid grid-cols-2 gap-3">
              {['Licensed in {0}'.replace('{0}', loc.stateAbbr),'Same-Day Available','24/7 Emergency','NATE-Certified'].map(badge => (
                <div class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-brand-sky flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  <span class="font-body text-sm text-white/80">{badge}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Neighborhoods served -->
          <div>
            <h2 class="font-display font-bold text-display-sm text-dark-900 mb-4">Neighborhoods We Serve in {loc.city}</h2>
            <div class="flex flex-wrap gap-2">
              {loc.neighborhoods.map(n => (
                <span class="font-body text-sm text-gray-600 bg-gray-100 px-3 py-1.5 rounded-full">{n}</span>
              ))}
            </div>
          </div>

        </div>

        <!-- Sidebar -->
        <div class="space-y-6">
          <ServiceSidebar siblingLinks={allLocLinks} currentHref={`/service-areas/${loc.slug}/`} />
        </div>

      </div>
    </div>
  </section>

  <TrustStripSection />
  <InPageCTA headline={`Schedule Service in ${loc.city} Today`} subline={`Call ${loc.phone} or book online. Same-day appointments available.`} />
</BaseLayout>
