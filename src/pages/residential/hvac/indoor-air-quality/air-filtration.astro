---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import PageHero from '../../../../components/ui/PageHero.astro';
import InPageCTA from '../../../../components/ui/InPageCTA.astro';
import ServiceSidebar from '../../../../components/ui/ServiceSidebar.astro';

const siblingLinks = [
  { label: 'Air Filtration & Purification', href: '/residential/hvac/indoor-air-quality/air-filtration/' },
  { label: 'Residential Duct Cleaning', href: '/residential/hvac/indoor-air-quality/duct-cleaning/' },
];
---
<BaseLayout
  title="Air Filtration & Purification Systems | Silver State"
  description="Whole-home air filtration, UV purifiers, and HEPA systems installed by licensed HVAC technicians. Cleaner air, healthier home. Serving 5 states."
>
  <PageHero eyebrow="Indoor Air Quality" title="Air Filtration & Purification — Cleaner Air Throughout Your Home"
    subtitle="Whole-home air filtration systems work with your existing HVAC to remove dust, allergens, bacteria, and viruses from every room — not just where a portable unit sits."
    breadcrumbs={[{label:'Residential',href:'/residential/'},{label:'HVAC',href:'/residential/hvac/'},{label:'Indoor Air Quality',href:'/residential/hvac/indoor-air-quality/'},{label:'Air Filtration',href:''}]} />
  <section class="section-pad bg-white">
    <div class="container-site">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        <div class="lg:col-span-2 space-y-8">
          <p class="font-body text-base text-gray-600 leading-relaxed">Silver State installs whole-home air filtration and purification systems that integrate directly with your HVAC system. Unlike portable units, these solutions treat 100% of the air circulating through your home continuously. We offer HEPA filtration, UV-C germicidal systems, electronic air cleaners, and advanced media filters tailored to your specific air quality concerns.</p>
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {['HEPA Filtration Installation','UV-C Germicidal System','Electronic Air Cleaners','Media Filter Upgrades','Whole-Home Air Purifiers','Humidity Control Solutions','Allergen Reduction Systems','Air Quality Testing'].map(s => (
              <li class="flex items-center gap-3 p-4 bg-gray-50 rounded-xl">
                <span class="w-5 h-5 rounded-full bg-brand-blue/10 flex items-center justify-center flex-shrink-0">
                  <svg class="w-3 h-3 text-brand-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                </span>
                <span class="font-body text-sm text-gray-700">{s}</span>
              </li>
            ))}
          </ul>
        </div>
        <ServiceSidebar siblingLinks={siblingLinks} currentHref="/residential/hvac/indoor-air-quality/air-filtration/" />
      </div>
    </div>
  </section>
  <InPageCTA />
</BaseLayout>
