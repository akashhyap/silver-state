---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import PageHero from '../../../../components/ui/PageHero.astro';
import InPageCTA from '../../../../components/ui/InPageCTA.astro';
import ServiceSidebar from '../../../../components/ui/ServiceSidebar.astro';

const siblingLinks = [
  { label: 'Air Filtration & Purification', href: '/residential/hvac/indoor-air-quality/air-filtration/' },
  { label: 'Residential Duct Cleaning', href: '/residential/hvac/indoor-air-quality/duct-cleaning/' },
];
---
<BaseLayout
  title="Residential Duct Cleaning Services | Silver State HVAC"
  description="Professional duct cleaning to remove dust, allergens, and debris from your home's ventilation system. Improve air quality and HVAC efficiency. Serving NV, CA, AZ, UT & TX."
>
  <PageHero eyebrow="Indoor Air Quality" title="Residential Duct Cleaning — Cleaner Ducts, Better Air"
    subtitle="Over years of operation, your ductwork accumulates dust, pet dander, mold spores, and debris that circulate through every room. Professional duct cleaning removes these contaminants at the source."
    breadcrumbs={[{label:'Residential',href:'/residential/'},{label:'HVAC',href:'/residential/hvac/'},{label:'Indoor Air Quality',href:'/residential/hvac/indoor-air-quality/'},{label:'Duct Cleaning',href:''}]} />
  <section class="section-pad bg-white">
    <div class="container-site">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        <div class="lg:col-span-2 space-y-8">
          <p class="font-body text-base text-gray-600 leading-relaxed">Silver State's residential duct cleaning uses NADCA (National Air Duct Cleaners Association) standard methods — powerful negative pressure equipment combined with agitation devices — to thoroughly clean supply ducts, return ducts, air handlers, and all registers throughout your home.</p>
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {['Full Supply & Return Duct Cleaning','Air Handler Cleaning','Register & Grille Cleaning','Duct Sanitizing','Mold Inspection & Treatment','Before & After Documentation','Dryer Vent Cleaning','Post-Cleaning Air Quality Check'].map(s => (
              <li class="flex items-center gap-3 p-4 bg-gray-50 rounded-xl">
                <span class="w-5 h-5 rounded-full bg-brand-blue/10 flex items-center justify-center flex-shrink-0">
                  <svg class="w-3 h-3 text-brand-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                </span>
                <span class="font-body text-sm text-gray-700">{s}</span>
              </li>
            ))}
          </ul>
        </div>
        <ServiceSidebar siblingLinks={siblingLinks} currentHref="/residential/hvac/indoor-air-quality/duct-cleaning/" />
      </div>
    </div>
  </section>
  <InPageCTA />
</BaseLayout>
