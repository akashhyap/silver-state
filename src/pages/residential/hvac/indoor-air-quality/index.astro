---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import PageHero from '../../../../components/ui/PageHero.astro';
import InPageCTA from '../../../../components/ui/InPageCTA.astro';
import ServiceSidebar from '../../../../components/ui/ServiceSidebar.astro';

const subServices = [
  { label: 'Air Filtration & Purification', href: '/residential/hvac/indoor-air-quality/air-filtration/' },
  { label: 'Residential Duct Cleaning', href: '/residential/hvac/indoor-air-quality/duct-cleaning/' },
];
---

<BaseLayout
  title="Indoor Air Quality Services | Air Filtration & Purification"
  description="Improve the air inside your home with Silver State's IAQ services — filtration, air purifiers, UV systems, and duct cleaning. Serving NV, CA, AZ, UT & TX."
>
  <PageHero
    eyebrow="Indoor Air Quality"
    title="Breathe Cleaner Air — IAQ Solutions for Your Home"
    subtitle="The air inside your home can be 2–5x more polluted than outdoor air. Silver State's indoor air quality services remove allergens, pollutants, and pathogens for a healthier living environment."
    breadcrumbs={[
      { label: 'Residential', href: '/residential/' },
      { label: 'HVAC', href: '/residential/hvac/' },
      { label: 'Indoor Air Quality', href: '' },
    ]}
  />

  <section class="section-pad bg-white">
    <div class="container-site">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        <div class="lg:col-span-2 space-y-8">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            {subServices.map(s => (
              <a href={s.href} class="group card p-6">
                <h3 class="font-display font-bold text-lg text-dark-900 group-hover:text-brand-blue transition-colors mb-2">{s.label}</h3>
                <span class="inline-flex items-center gap-1.5 mt-2 font-body font-semibold text-sm text-brand-blue group-hover:gap-2.5 transition-all">
                  Learn More <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
                </span>
              </a>
            ))}
          </div>
        </div>
        <ServiceSidebar siblingLinks={subServices} currentHref="/residential/hvac/indoor-air-quality/" />
      </div>
    </div>
  </section>
  <InPageCTA />
</BaseLayout>
