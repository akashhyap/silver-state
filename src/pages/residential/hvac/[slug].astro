---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHero from '../../../components/ui/PageHero.astro';
import InPageCTA from '../../../components/ui/InPageCTA.astro';
import ServiceSidebar from '../../../components/ui/ServiceSidebar.astro';
import { hvacSpokes } from '../../../data/siteData';

export async function getStaticPaths() {
  return hvacSpokes.map(spoke => ({
    params: { slug: spoke.slug },
    props: { spoke },
  }));
}

const { spoke } = Astro.props;

const siblingLinks = hvacSpokes.map(s => ({
  label: s.title,
  href: `/residential/hvac/${s.slug}/`,
}));

const relatedSpokes = hvacSpokes.filter(s => spoke.related?.includes(s.slug));
---

<BaseLayout title={spoke.metaTitle} description={spoke.metaDesc}>
  <PageHero
    eyebrow="Residential HVAC"
    title={spoke.headline}
    subtitle={spoke.intro}
    breadcrumbs={[
      { label: 'Residential', href: '/residential/' },
      { label: 'HVAC', href: '/residential/hvac/' },
      { label: spoke.title, href: '' },
    ]}
  />

  <section class="section-pad bg-white">
    <div class="container-site">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">

        <!-- Main content -->
        <div class="lg:col-span-2 space-y-10">

          <!-- Services included -->
          <div>
            <h2 class="font-display font-bold text-display-sm text-dark-900 mb-5">What's Included</h2>
            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              {spoke.services.map(service => (
                <li class="flex items-start gap-3 p-4 bg-gray-50 rounded-xl">
                  <span class="flex-shrink-0 mt-0.5 w-5 h-5 rounded-full bg-brand-blue/10 flex items-center justify-center">
                    <svg class="w-3 h-3 text-brand-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                    </svg>
                  </span>
                  <span class="font-body text-sm text-gray-700">{service}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Why Silver State -->
          <div class="bg-brand-navy rounded-3xl p-8 text-white">
            <h2 class="font-display font-bold text-xl mb-4">Why Choose Silver State?</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {[
                { icon: '🛡️', title: 'NATE-Certified', desc: 'Every technician is NATE-certified and fully trained.' },
                { icon: '⚡', title: 'Same-Day Service', desc: 'Most calls are serviced the same day.' },
                { icon: '💰', title: 'Transparent Pricing', desc: 'No hidden fees. No surprises on your invoice.' },
                { icon: '🕐', title: '24/7 Available', desc: 'Day or night — we\'re here when you need us.' },
              ].map(item => (
                <div class="flex gap-3">
                  <span class="text-xl flex-shrink-0">{item.icon}</span>
                  <div>
                    <p class="font-display font-semibold text-sm text-white">{item.title}</p>
                    <p class="font-body text-xs text-white/60 mt-0.5">{item.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- FAQs -->
          {spoke.faqs && spoke.faqs.length > 0 && (
            <div>
              <h2 class="font-display font-bold text-display-sm text-dark-900 mb-5">Frequently Asked Questions</h2>
              <div class="space-y-4">
                {spoke.faqs.map(faq => (
                  <details class="group border border-gray-200 rounded-2xl overflow-hidden">
                    <summary class="flex items-center justify-between gap-4 cursor-pointer p-5 font-display font-semibold text-base text-dark-900 list-none hover:bg-gray-50 transition-colors">
                      {faq.q}
                      <svg class="w-5 h-5 text-brand-blue flex-shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                      </svg>
                    </summary>
                    <div class="px-5 pb-5">
                      <p class="font-body text-sm text-gray-600 leading-relaxed">{faq.a}</p>
                    </div>
                  </details>
                ))}
              </div>
            </div>
          )}

          <!-- Related services -->
          {relatedSpokes.length > 0 && (
            <div>
              <h2 class="font-display font-bold text-display-sm text-dark-900 mb-5">Related Services</h2>
              <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                {relatedSpokes.map(rel => (
                  <a href={`/residential/hvac/${rel.slug}/`} class="group card p-5">
                    <h3 class="font-display font-semibold text-sm text-dark-900 group-hover:text-brand-blue transition-colors mb-1">{rel.title}</h3>
                    <p class="font-body text-xs text-gray-500 line-clamp-2">{rel.intro.slice(0,80)}...</p>
                  </a>
                ))}
              </div>
            </div>
          )}

        </div>

        <!-- Sidebar -->
        <ServiceSidebar siblingLinks={siblingLinks} currentHref={`/residential/hvac/${spoke.slug}/`} />

      </div>
    </div>
  </section>

  <InPageCTA />
</BaseLayout>
