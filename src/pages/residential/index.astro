---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/ui/PageHero.astro';
import InPageCTA from '../../components/ui/InPageCTA.astro';
import TrustStripSection from '../../components/sections/TrustStripSection.astro';

const hvacServices = [
  { label: 'AC Repair', href: '/residential/hvac/ac-repair/' },
  { label: 'AC Installation', href: '/residential/hvac/ac-installation/' },
  { label: 'Furnace Repair', href: '/residential/hvac/furnace-repair/' },
  { label: 'Furnace Installation', href: '/residential/hvac/furnace-installation/' },
  { label: 'Heat Pump Services', href: '/residential/hvac/heat-pump-services/' },
  { label: 'Mini-Split Systems', href: '/residential/hvac/mini-split-systems/' },
  { label: 'HVAC Maintenance', href: '/residential/hvac/hvac-maintenance/' },
  { label: 'Emergency HVAC', href: '/residential/hvac/emergency-hvac/' },
  { label: 'Indoor Air Quality', href: '/residential/hvac/indoor-air-quality/' },
  { label: 'Smart Thermostats', href: '/residential/hvac/smart-thermostats/' },
];

const plumbingServices = [
  { label: 'Drain Cleaning', href: '/residential/plumbing/drain-cleaning/' },
  { label: 'Leak Detection & Repair', href: '/residential/plumbing/leak-detection-repair/' },
  { label: 'Water Heater Repair', href: '/residential/plumbing/water-heater-repair/' },
  { label: 'Water Heater Installation', href: '/residential/plumbing/water-heater-installation/' },
  { label: 'Tankless Water Heaters', href: '/residential/plumbing/tankless-water-heaters/' },
  { label: 'Water Softeners', href: '/residential/plumbing/water-softeners/' },
  { label: 'Pipe Repair & Replacement', href: '/residential/plumbing/pipe-repair-replacement/' },
  { label: 'Bathroom Plumbing', href: '/residential/plumbing/bathroom-plumbing/' },
  { label: 'Sewer Line Services', href: '/residential/plumbing/sewer-line-services/' },
  { label: 'ManaBloc Systems', href: '/residential/plumbing/manabloc-systems/' },
];
---

<BaseLayout
  title="Residential HVAC & Plumbing Services"
  description="Expert residential HVAC and plumbing services across Nevada, California, Arizona, Utah & Texas. AC repair, furnace installation, water heaters, drain cleaning and more."
>
  <PageHero
    eyebrow="Residential Services"
    title="Complete Residential HVAC & Plumbing"
    subtitle="Your home deserves the best. From AC repair in summer heat to furnace installation before winter — our NATE-certified team keeps your home comfortable year-round."
    breadcrumbs={[{ label: 'Residential', href: '' }]}
  />

  <section class="section-pad bg-white">
    <div class="container-site">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
        <!-- HVAC -->
        <div>
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-xl bg-blue-50 flex items-center justify-center">
              <svg class="w-5 h-5 text-brand-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
              </svg>
            </div>
            <div>
              <h2 class="font-display font-bold text-xl text-dark-900">Heating & Cooling</h2>
              <a href="/residential/hvac/" class="font-body text-sm text-brand-blue hover:underline">View all HVAC services →</a>
            </div>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
            {hvacServices.map(s => (
              <a href={s.href} class="flex items-center gap-2 p-3 rounded-xl border border-gray-100 hover:border-brand-blue/30 hover:bg-blue-50/50 transition-all group">
                <svg class="w-3.5 h-3.5 text-brand-blue flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
                <span class="font-body text-sm text-gray-700 group-hover:text-brand-blue transition-colors">{s.label}</span>
              </a>
            ))}
          </div>
        </div>
        <!-- Plumbing -->
        <div>
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-xl bg-blue-50 flex items-center justify-center">
              <svg class="w-5 h-5 text-brand-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
              </svg>
            </div>
            <div>
              <h2 class="font-display font-bold text-xl text-dark-900">Plumbing</h2>
              <a href="/residential/plumbing/" class="font-body text-sm text-brand-blue hover:underline">View all plumbing services →</a>
            </div>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
            {plumbingServices.map(s => (
              <a href={s.href} class="flex items-center gap-2 p-3 rounded-xl border border-gray-100 hover:border-brand-blue/30 hover:bg-blue-50/50 transition-all group">
                <svg class="w-3.5 h-3.5 text-brand-blue flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
                <span class="font-body text-sm text-gray-700 group-hover:text-brand-blue transition-colors">{s.label}</span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <TrustStripSection />
  <InPageCTA />
</BaseLayout>
