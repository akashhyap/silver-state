---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/ui/PageHero.astro';
import { locations } from '../data/siteData';

const primaryLocations = locations.filter(l =>
  ['las-vegas-nv', 'phoenix-az', 'sacramento-ca'].includes(l.slug)
);
---

<BaseLayout
  title="Contact Us | Silver State HVAC & Plumbing"
  description="Contact Silver State for HVAC, plumbing, and refrigeration services. Same-day appointments, 24/7 emergency service. Serving NV, CA, AZ, UT & TX."
>
  <PageHero
    eyebrow="Contact Us"
    title="Get In Touch — We're Ready to Help"
    subtitle="Fill out the form below or call us directly. Same-day appointments are available across all markets."
    breadcrumbs={[{ label: 'Contact Us', href: '' }]}
  />

  <section class="section-pad bg-white">
    <div class="container-site">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">

        <!-- Form -->
        <div class="lg:col-span-2">
          <h2 class="font-display font-bold text-display-sm text-dark-900 mb-6">Request Service or Get a Free Estimate</h2>
          <form class="space-y-5" onsubmit="return false;">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label class="font-body text-sm font-medium text-gray-700 mb-1.5 block">Full Name *</label>
                <input type="text" placeholder="John Smith" class="w-full border border-gray-200 rounded-xl px-4 py-3 font-body text-sm text-gray-700 focus:outline-none focus:border-brand-blue focus:ring-2 focus:ring-brand-blue/10 transition-all" required />
              </div>
              <div>
                <label class="font-body text-sm font-medium text-gray-700 mb-1.5 block">Phone Number *</label>
                <input type="tel" placeholder="(702) 555-0000" class="w-full border border-gray-200 rounded-xl px-4 py-3 font-body text-sm text-gray-700 focus:outline-none focus:border-brand-blue focus:ring-2 focus:ring-brand-blue/10 transition-all" required />
              </div>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label class="font-body text-sm font-medium text-gray-700 mb-1.5 block">Email Address</label>
                <input type="email" placeholder="john@example.com" class="w-full border border-gray-200 rounded-xl px-4 py-3 font-body text-sm text-gray-700 focus:outline-none focus:border-brand-blue focus:ring-2 focus:ring-brand-blue/10 transition-all" />
              </div>
              <div>
                <label class="font-body text-sm font-medium text-gray-700 mb-1.5 block">ZIP Code</label>
                <input type="text" placeholder="89101" class="w-full border border-gray-200 rounded-xl px-4 py-3 font-body text-sm text-gray-700 focus:outline-none focus:border-brand-blue focus:ring-2 focus:ring-brand-blue/10 transition-all" />
              </div>
            </div>
            <div>
              <label class="font-body text-sm font-medium text-gray-700 mb-1.5 block">Service Type</label>
              <select class="w-full border border-gray-200 rounded-xl px-4 py-3 font-body text-sm text-gray-700 focus:outline-none focus:border-brand-blue focus:ring-2 focus:ring-brand-blue/10 transition-all bg-white">
                <option value="">Select a service...</option>
                <option>AC Repair / HVAC Emergency</option>
                <option>AC Installation or Replacement</option>
                <option>Furnace Repair or Installation</option>
                <option>HVAC Maintenance Tune-Up</option>
                <option>Plumbing Repair</option>
                <option>Water Heater Service</option>
                <option>Drain Cleaning</option>
                <option>Commercial HVAC</option>
                <option>Commercial Refrigeration</option>
                <option>Other</option>
              </select>
            </div>
            <div>
              <label class="font-body text-sm font-medium text-gray-700 mb-1.5 block">Describe Your Issue</label>
              <textarea rows="4" placeholder="Tell us what's happening so we can send the right technician..." class="w-full border border-gray-200 rounded-xl px-4 py-3 font-body text-sm text-gray-700 focus:outline-none focus:border-brand-blue focus:ring-2 focus:ring-brand-blue/10 transition-all resize-none"></textarea>
            </div>
            <p class="font-body text-xs text-gray-400 leading-relaxed">By submitting this form, I agree to receive SMS messages about appointments, alerts, and promotions from Silver State Refrigeration, HVAC & Plumbing. Reply STOP to opt out.</p>
            <button type="submit" class="btn-primary w-full justify-center">
              Request Service
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            </button>
          </form>
        </div>

        <!-- Contact info -->
        <div class="space-y-6">
          <div class="bg-brand-navy rounded-2xl p-6 text-white">
            <p class="font-body text-xs text-brand-sky uppercase tracking-widest font-semibold mb-4">Emergency Line</p>
            <p class="font-body text-sm text-white/70 mb-2">Available 24/7 — day or night</p>
            <a href="tel:7252137309" class="font-display font-bold text-2xl text-white hover:text-brand-sky transition-colors">(725) 213-7309</a>
            <div class="mt-4 flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse flex-shrink-0"></span>
              <span class="font-body text-sm text-green-400 font-semibold">Available Now</span>
            </div>
          </div>

          <div class="card p-5 space-y-4">
            <p class="font-body text-xs text-brand-blue uppercase tracking-widest font-semibold">Market Offices</p>
            {primaryLocations.map(loc => (
              <div class="border-b border-gray-100 pb-4 last:border-0 last:pb-0">
                <p class="font-display font-semibold text-sm text-dark-900">{loc.city}, {loc.stateAbbr}</p>
                <p class="font-body text-xs text-gray-400 mt-0.5">{loc.address}</p>
                <a href={`tel:${loc.phoneRaw}`} class="font-body text-sm text-brand-blue font-semibold hover:underline mt-1 block">{loc.phone}</a>
              </div>
            ))}
            <a href="/service-areas/" class="font-body text-sm text-brand-blue hover:underline block">View all service areas →</a>
          </div>

          <div class="bg-gray-50 rounded-2xl p-5">
            <p class="font-body text-xs text-brand-blue uppercase tracking-widest font-semibold mb-3">Hours</p>
            <p class="font-body text-sm text-gray-600 leading-relaxed">Monday – Sunday, 24/7. Emergency service always available.</p>
          </div>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>
