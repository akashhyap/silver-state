---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/ui/PageHero.astro';
import InPageCTA from '../../components/ui/InPageCTA.astro';
import ServiceSidebar from '../../components/ui/ServiceSidebar.astro';
import { commercialSpokes } from '../../data/siteData';

export async function getStaticPaths() {
  return commercialSpokes.map(spoke => ({
    params: { slug: spoke.slug },
    props: { spoke },
  }));
}

const { spoke } = Astro.props;

const siblingLinks = commercialSpokes.map(s => ({
  label: s.title,
  href: `/commercial/${s.slug}/`,
}));
---

<BaseLayout title={spoke.metaTitle} description={spoke.metaDesc}>
  <PageHero
    eyebrow="Commercial Services"
    title={spoke.headline}
    subtitle={spoke.intro}
    breadcrumbs={[
      { label: 'Commercial', href: '/commercial/' },
      { label: spoke.title, href: '' },
    ]}
    bg="navy"
  />

  <section class="section-pad bg-white">
    <div class="container-site">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        <div class="lg:col-span-2 space-y-10">
          <div>
            <h2 class="font-display font-bold text-display-sm text-dark-900 mb-5">Our {spoke.title} Services</h2>
            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              {spoke.services.map(service => (
                <li class="flex items-start gap-3 p-4 bg-gray-50 rounded-xl">
                  <span class="flex-shrink-0 mt-0.5 w-5 h-5 rounded-full bg-brand-blue/10 flex items-center justify-center">
                    <svg class="w-3 h-3 text-brand-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  </span>
                  <span class="font-body text-sm text-gray-700">{service}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="bg-brand-navy rounded-3xl p-8 text-white">
            <h2 class="font-display font-bold text-xl mb-2">Commercial Maintenance Agreements</h2>
            <p class="font-body text-white/70 text-sm leading-relaxed mb-5">Protect your business with a Silver State maintenance agreement — scheduled service visits, priority emergency response, discounted repair rates, and full documentation for compliance.</p>
            <a href="/contact-us/" class="btn-dark self-start inline-flex">Request a Quote <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg></a>
          </div>
        </div>
        <ServiceSidebar siblingLinks={siblingLinks} currentHref={`/commercial/${spoke.slug}/`} />
      </div>
    </div>
  </section>
  <InPageCTA headline="Commercial Emergency? We Respond 24/7." subline="Don't let equipment failure shut down your business. Call us now." />
</BaseLayout>
