---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/ui/PageHero.astro';
import InPageCTA from '../components/ui/InPageCTA.astro';
---
<BaseLayout title="Financing Options | Silver State HVAC & Plumbing" description="Get the HVAC or plumbing service you need now with flexible financing options. Apply today.">
  <PageHero eyebrow="Financing" title="Flexible Financing — Get the Comfort You Need Now" subtitle="Don't let budget be the reason you wait on essential HVAC or plumbing repairs. We offer flexible financing options to fit your situation." breadcrumbs={[{label:'Financing',href:''}]} />
  <section class="section-pad bg-white">
    <div class="container-site max-w-3xl mx-auto text-center">
      <h2 class="font-display font-bold text-display-sm text-dark-900 mb-6">How Financing Works</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
        {[
          { step: '1', title: 'Apply Online or In-Home', desc: 'Quick application — most decisions in minutes.' },
          { step: '2', title: 'Get Approved', desc: 'Flexible terms available for a wide range of credit situations.' },
          { step: '3', title: 'Schedule Your Service', desc: 'Book your installation or repair immediately after approval.' },
        ].map(s => (
          <div class="card p-6 text-center">
            <div class="w-10 h-10 rounded-full bg-brand-blue text-white font-display font-bold text-lg flex items-center justify-center mx-auto mb-3">{s.step}</div>
            <h3 class="font-display font-bold text-base text-dark-900 mb-2">{s.title}</h3>
            <p class="font-body text-sm text-gray-500">{s.desc}</p>
          </div>
        ))}
      </div>
      <p class="font-body text-sm text-gray-500 mb-6">Financing is available on qualifying HVAC installations, water heater replacements, and other larger projects. Subject to credit approval. Contact us for details.</p>
      <a href="/contact-us/" class="btn-primary inline-flex mx-auto">Ask About Financing <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg></a>
    </div>
  </section>
  <InPageCTA />
</BaseLayout>
